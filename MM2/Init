function GrabGun(isDestroy)
    if not isDestroy then
        if not IsAlive(Speaker) then return end
        if __gameInfo.Murder.Name == Speaker.Name then return end

        local Character = Speaker.Character
        if not Character then return end

        local Root = GetRoot()
        if not Root then return end

        local Map = GetMap()
        if not Map then return end

        local GunDrop = Map:FindFirstChild('GunDrop')
        if not GunDrop then return end

        GunDrop.CFrame = Root.CFrame
    else
        return
    end
end

function KillAll()
    if __gameInfo.Murder.Name ~= Speaker.Name then return end
    if CheckItem('Knife') == false then return end
    
    local Knife = GrabItem('Knife')
    if not Knife then return end

    for __player, player in pairs(Players:GetChildren()) do
        Kill(player)
    end
end

function ShootMurder(Teleport)
    if __gameInfo.Murder.Name == nil then return end
    if CheckItem('Gun') == false then return end
    
    local Gun = GrabItem('Gun')
    if not Gun then return end

    local Remote = Gun:FindFirstChild("Shoot")
    if not Remote then return end
    
    local Murderer = Players:FindFirstChild(__gameInfo.Murder.Name)
    if not Murderer or not Murderer.Character then return end
    
    local MurdRoot = Murderer.Character:FindFirstChild('HumanoidRootPart')
    if not MurdRoot then return end

    local MyRoot = GetRoot()
    if not MyRoot then return end
    
    local OldPosition = MyRoot.CFrame
    
    if Teleport then
        MyRoot.CFrame = MurdRoot.CFrame * CFrame.new(0, 0, 5)
        task.wait(0.1)
    end

    local Position = Predict(MurdRoot)
    if not Position then return end

    pcall(function()
        Remote:FireServer(Gun:GetPivot(), CFrame.new(Position))
    end)

    if Teleport then
        task.spawn(function()
            task.wait(0.2)
            local Root = GetRoot()
            if Root then
                Root.CFrame = OldPosition
            end
        end)
    end
end

function ChangeMod(Type, Value)
    if not Speaker then return end

    local Hum = GetHum()
    if not Hum then return end

    if Type == 'ws' then
        Hum.WalkSpeed = Value
    elseif Type == 'jp' then
        Hum.JumpPower = Value
    end
end

function Teleport(Place)
    if not Speaker then return end
    
    local HumRoot = GetRoot()
    if not HumRoot then return end

    if Place == 'map' then
        local Map = GetMap()
        if not Map then return end

        local Spawns = Map:FindFirstChild('Spawns')
        if not Spawns then return end

        HumRoot.CFrame = Spawns:GetChildren()[math.random(1, #Spawns:GetChildren())].CFrame * CFrame.new(0, 3, 0)
    elseif Place == 'lobby' then
        local Spawns = Workspace:FindFirstChild('Lobby'):FindFirstChild('Spawns')
        if not Spawns then return end
        
        HumRoot.CFrame = Spawns:GetChildren()[math.random(1, #Spawns:GetChildren())].CFrame * CFrame.new(0, 4, 0)
    elseif Place == 'top' then
        local Map = GetMap()
        if not Map then return end

        local Spawns = Map:FindFirstChild('Spawns')
        if not Spawns then return end

        for _, part in pairs(Map.Base:GetDescendants()) do
            if part.Name == 'KillBrick' then
                part:Destroy()
            end
        end

        RandomSpawn = Spawns:GetChildren()[math.random(1, #Spawns:GetChildren())]
        HumRoot.CFrame = CFrame.new(Raycast(Spawns, RandomSpawn)) * CFrame.new(0, 4, 0)
    elseif Place == 'murderer' then
        local MurdRoot = GetRoot(workspace:FindFirstChild(__gameInfo.Murder.Name))
        if not MurdRoot then return end

        HumRoot.CFrame = MurdRoot.CFrame * CFrame.new(0, 0, 4)
    elseif Place == 'sheriff' then
        local SheriffRoot = GetRoot(workspace:FindFirstChild(__gameInfo.Sheriff.Name))
        if not SheriffRoot then return end

        HumRoot.CFrame = SheriffRoot.CFrame * CFrame.new(0, 0, 4)
    end
end

