    for _, connection in __gameInfo.Connections do
        if connection then
            connection:Disconnect()
		    connection = nil
        end
    end

    getgenv().Configuration('save')
    task.wait(1)
    for _, player in Players:GetPlayers() do
        if player then
            CreateHighlight(player, true)
            if __gameInfo.Tracers[player] then __gameInfo.Tracers[player]:Remove() end
            if __gameInfo.Names[player] then __gameInfo.Names[player]:Remove() end
        end
    end
    
    ChangeMod('ws', 16)
    ChangeMod('jp', 50)
    AntiFling(true)
    AntiAFK(true)
end)

