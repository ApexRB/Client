            }
            table.insert(list, PlayerTable)
        end
    end

    for __Dropdown, Dropdown in pairs(__gameInfo.Dropdowns) do
        Dropdown:Refresh(list)
    end
end

local function CreateHighlight(Player, IsDestroy)
    if not Player or not Player.Character then return end
    
    if IsDestroy then
        if Player.Character:FindFirstChildOfClass('Highlight') then
            Player.Character.Highlight:Destroy()
        end
    else
        if not Player.Character:FindFirstChildOfClass('Highlight') then
            local Highlight = Instance.new('Highlight')
            Highlight.Parent = Player.Character
            return Highlight
        end
        return Player.Character:FindFirstChildOfClass('Highlight')
    end
end

local function Predict(Part)
    local Hum = GetHum(Part.Parent)

    if not Part or not Hum then return end
        
    local Velocity = Part.AssemblyLinearVelocity
    local MoveDirection = Hum.MoveDirection

    local Ping = Speaker:GetNetworkPing()
    local Offset = 3
        
    local PredictedPos = Part.Position 
        + Velocity * Ping 
        + MoveDirection * Offset * (1 + Ping * 2)
        + Vector3.new(0, Part.Size.Y * 0.25, 0)
        
    return PredictedPos
end

local function CreateTracer(Player)
