end

local function Raycast(spawnModel, spawnPart)
    if not spawnModel or not spawnPart then return end

    local raisedCFrame = spawnPart.CFrame + Vector3.new(0, 350, 0)
    local raisedBottomCFrame = raisedCFrame + Vector3.new(0, -(spawnPart.Size.Y / 2), 0)

    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {spawnModel}
    raycastParams.IgnoreWater = true

    local raycastResult = workspace:Raycast(
        raisedBottomCFrame.Position + Vector3.new(0, 0.01, 0), 
        Vector3.new(0, -2000, 0), 
        raycastParams
    )

    local stopPos
    if raycastResult then
        local hitPos = raycastResult.Position
        stopPos = raycastResult.Position
    else
        stopPos = Vector3.new(spawnPart.Position.X, spawnPart.Position.Y - 1000, spawnPart.Position.Z)
    end
    return stopPos
end

local function Kill(Player)
    if Player == Speaker then return end

    if not Player or not Player.Character then return end
    if not IsAlive(Player) then return end

    if table.find(__gameInfo.Whitelist, Player.Name) then return end

    local Events = Knife:FindFirstChild('Events')
    if not Events then return end

    Events.HandleTouched:FireServer(game.Workspace[Player.Name].UpperTorso)
end

local function Throw(Knife, Player)
    if Player == Speaker then return end

    if not Player or not Player.Character then return end
    if not IsAlive(Player) then return end

    if table.find(__gameInfo.Whitelist, Player.Name) then return end

    local Events = Knife:FindFirstChild('Events')
    if not Events then return end

    Events.KnifeThrown:FireServer(Knife.Handle.CFrame, GetRoot(Player, true).CFrame)
end

local function GetNearest()
    local HumRoot = GetRoot()
    if not HumRoot then return end
    
    local NearestPlayer = nil
    local NearestDistance = math.huge()
    
    for __player, player in ipairs(game.Players:GetPlayers()) do
        if player == game.Players.LocalPlayer then continue end

        local T_HumRoot = GetRoot(player, true)
        if not T_HumRoot then continue end

        local Distance = (HumRoot.Position - T_HumRoot.Position).Magnitude
         if Distance < NearestDistance then
            NearestPlayer = player
            NearestDistance = Distance
        end
    end
    
    return nearestPlayer
end
