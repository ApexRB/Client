-- // MAIN USABLE FUNCTIONS // --
local function GetRoot(Character, __N)
    if __N ~= nil then
        if not Character then return end
    end

    Character = Character or Speaker.Character
    if not Character then return end

    local HumRoot = Character:FindFirstChild('HumanoidRootPart')
    if not HumRoot then return end

    return HumRoot
end

local function GetHum(Character, __N)
    if __N ~= nil then
        if not Character then return end
    end

    Character = Character or Speaker.Character
    if not Character then return end

    local Hum = Character:FindFirstChild('Humanoid')
    if not Hum then return end

    return Hum
end

local function GetMap()
    local map

    for _, model in pairs(Workspace:GetChildren()) do
		if model:IsA('Model') and model:GetAttribute("MapID") then
			map = model
		end
	end

    return map
end

local function CheckItem(ItemName)
    if Speaker.Backpack:FindFirstChild(ItemName) then
        return true
    elseif Speaker.Character:FindFirstChild(ItemName) then
        return true
    end
    return false
end

local function GrabItem(ItemName)
    if Speaker.Backpack:FindFirstChild(ItemName) then
        Speaker.Backpack[ItemName].Parent = Speaker.Character
    end

    return Speaker.Character[ItemName]
end

local function IsAlive(Player)
    if not Player then return false end

	for i, v in pairs(Data) do
		if Player.Name == i then
			if not v.Killed and not v.Dead then
				return true
			else
				return false
			end
		end
	end
end

