    for __player, player in pairs(Data) do
        if player.Role == "Murderer" then
            __gameInfo.Murder.Name = __player
        elseif player.Role == 'Sheriff'then
            __gameInfo.Sheriff.Name = __player
        elseif player.Role == 'Hero'then
            __gameInfo.Hero.Name = __player
        end
    end

    -- Highlight Updater --
    for __player, player in pairs(Players:GetChildren()) do
        if player == Speaker then continue end

        if player and player.Name == __gameInfo.Murder.Name and IsAlive(player) then

            if __gameInfo.Murder.Highlight == false then
                CreateHighlight(player, true)
            else
                local Highlight = CreateHighlight(player, false)
                if not Highlight then return end
                
                Highlight.FillColor = __gameInfo.Murder.Color
                Highlight.FillTransparency = 0.7
                Highlight.OutlineColor = __gameInfo.Murder.Color
            end

        elseif player and player.Name == __gameInfo.Sheriff.Name and IsAlive(player) then

            if __gameInfo.Sheriff.Highlight == false then
                CreateHighlight(player, true)
            else
                local Highlight = CreateHighlight(player, false)
                if not Highlight then return end
                
                Highlight.FillColor = __gameInfo.Sheriff.Color
                Highlight.FillTransparency = 0.7
                Highlight.OutlineColor = __gameInfo.Sheriff.Color
            end

        elseif player and player.Name == __gameInfo.Hero.Name and IsAlive(player) then

            if __gameInfo.Hero.Highlight == false then
                CreateHighlight(player, true)
            else
                local Highlight = CreateHighlight(player, false)
                if not Highlight then return end
                
                Highlight.FillColor = __gameInfo.Hero.Color
                Highlight.FillTransparency = 0.7
                Highlight.OutlineColor = __gameInfo.Hero.Color
            end

        else
            if __gameInfo.Innocent.Highlight == true then
                local Highlight = CreateHighlight(player, false)
                if not Highlight then return end

                Highlight.FillColor = __gameInfo.Innocent.Color
                Highlight.FillTransparency = 0.7
                Highlight.OutlineColor = __gameInfo.Innocent.Color
            else
                CreateHighlight(player, true)
            end
        end
